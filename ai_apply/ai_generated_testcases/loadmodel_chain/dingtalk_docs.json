  "simArcs.webMoveObject": {
    "func": "simArcs.webMoveObject",
    "description": "",
    "params": [
      {
        "name": "object_handle",
        "description": "模型handle"
      },
      {
        "name": "delta_dist",
        "description": "相对于自身而言，x，y，z轴的变化量数组，[∆x, ∆y, ∆z]，正数代表向轴的正方向移动，负数代表向轴的负方向移动；相对于世界，那么就代表目标值"
      },
      {
        "name": "relative_to_object_handle",
        "description": "参考对象handle，默认-1，可省略\n*    -1: world \n    \n*    -11: parent\n    \n*   场景中存在handle的对象"
      },
      {
        "name": "unit",
        "description": "单位，1:mm，2:cm，3:dm，4:m，可省略，默认是m"
      },
      {
        "name": "success",
        "description": "成功返回true,失败返回false"
      }
    ],
    "request_example": "{  <br>    \"func\": \"simArcs.webMoveObject\",  <br>    \"args\": \\[  <br>        15,  <br>        \\[0.1,0,0\\],  <br>        -1,  <br>        3  <br>    \\]  <br>}",
    "response_example": "{  <br>    \"ret\": \\[  <br>        true  <br>    \\],  <br>    \"success\": true  <br>}",
    "source": "local_md"
  },
