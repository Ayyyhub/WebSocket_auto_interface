{
  "interfaces": [
    {
      "func": "sim.loadModel",
      "description": "loadModel 加载模型",
      "test_scenarios": [
        {
          "name": "test_loadModel_normal",
          "description": "正常加载有效模型路径",
          "category": "normal",
          "priority": 1,
          "target_params": {
            "路径": "public/models/robot/AIR4_560A/AIR4_560A.m"
          },
          "expected": {
            "should_success": true
          },
          "args": [
            ""
          ]
        },
        {
          "name": "test_loadModel_boundary_empty_path",
          "description": "路径为空字符串（边界值）",
          "category": "boundary",
          "priority": 2,
          "target_params": {
            "路径": ""
          },
          "expected": {
            "should_success": false
          },
          "args": [
            "\"public/models/robot/AIR4_560A/AIR4_560A.m\""
          ]
        },
        {
          "name": "test_loadModel_wrong_arg_type_path",
          "description": "路径参数类型为非字符串（错误类型）",
          "category": "wrong_arg_type",
          "priority": 3,
          "target_params": {
            "路径": 12345
          },
          "expected": {
            "should_success": false
          },
          "args": [
            12345
          ]
        },
        {
          "name": "test_loadModel_missing_args",
          "description": "缺少路径参数（应使用空数组或未传参数）",
          "category": "missing_args",
          "priority": 4,
          "target_params": {
            "路径": ""
          },
          "expected": {
            "should_success": false
          },
          "args": []
        },
        {
          "name": "test_loadModel_violation_invalid_path",
          "description": "模型路径无效或不存在（业务规则违反）",
          "category": "violation",
          "priority": 5,
          "target_params": {
            "路径": "invalid/path/to/model.m"
          },
          "expected": {
            "should_success": false
          },
          "args": [
            ""
          ]
        },
        {
          "name": "test_loadModel_invalid_func",
          "description": "调用不存在的接口",
          "category": "invalid_func",
          "priority": 6,
          "target_params": {},
          "expected": {
            "should_success": false
          },
          "args": []
        },
        {
          "name": "test_loadModel_null_args",
          "description": "路径参数为null",
          "category": "null_args",
          "priority": 7,
          "target_params": {
            "路径": null
          },
          "expected": {
            "should_success": false
          },
          "args": [
            null
          ]
        }
      ]
    },
