    {
      "func": "sim.loadModel",
      "description": "加载模型接口，用于初始化模型对象，为后续操作提供基础对象句柄。",
      "test_scenarios": [
        {
          "name": "test_loadModel_normal",
          "description": "正常加载存在的模型路径，返回模型句柄。",
          "category": "normal",
          "priority": 1,
          "target_params": {
            "模型路径": "有效模型路径"
          },
          "expected": {
            "should_success": true
          },
          "args": [
            ""
          ]
        },
        {
          "name": "test_loadModel_boundary_empty_path",
          "description": "模型路径为空字符串，测试边界条件。",
          "category": "boundary",
          "priority": 2,
          "target_params": {
            "模型路径": ""
          },
          "expected": {
            "should_success": false
          },
          "args": [
            "\"public/models/robot/AIR4_560A/AIR4_560A.m\""
          ]
        },
        {
          "name": "test_loadModel_wrong_arg_type",
          "description": "模型路径参数传入整数类型，类型错误。",
          "category": "wrong_arg_type",
          "priority": 2,
          "target_params": {
            "模型路径": 12345
          },
          "expected": {
            "should_success": false
          },
          "args": [
            12345
          ]
        },
        {
          "name": "test_loadModel_missing_args",
          "description": "未传入模型路径参数，缺少参数。",
          "category": "missing_args",
          "priority": 2,
          "target_params": {
            "模型路径": null
          },
          "expected": {
            "should_success": false
          },
          "args": []
        },
        {
          "name": "test_loadModel_violation_duplicate_load",
          "description": "重复加载同一模型，违反资源管理规则（假设系统不允许重复加载同一模型）。",
          "category": "violation",
          "priority": 3,
          "target_params": {
            "模型路径": "已加载的模型路径"
          },
          "expected": {
            "should_success": false
          },
          "args": [
            ""
          ]
        },
        {
          "name": "test_loadModel_invalid_func",
          "description": "调用不存在的加载模型接口。",
          "category": "invalid_func",
          "priority": 3,
          "target_params": {},
          "expected": {
            "should_success": false
          },
          "args": []
        },
        {
          "name": "test_loadModel_null_args",
          "description": "模型路径参数传null，测试空值场景。",
          "category": "null_args",
          "priority": 2,
          "target_params": {
            "模型路径": null
          },
          "expected": {
            "should_success": false
          },
          "args": [
            null
          ]
        }
      ]
    },
