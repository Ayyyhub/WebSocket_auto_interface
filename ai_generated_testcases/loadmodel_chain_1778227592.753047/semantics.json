{
  "interfaces": [
    {
      "func": "sim.loadModel",
      "seq": 1,
      "business_meaning": "加载指定路径的模型文件并初始化模型对象，返回模型对象的唯一标识符。",
      "interface_type": "command",
      "params": [
        {
          "index": 0,
          "params_name": "model_path",
          "type": "str",
          "required": 0,
          "valid_range": "文件路径字符串",
          "boundary_values": [],
          "enum_values": [],
          "special_char_limit": "路径中不能包含非法字符，如 \\:*?\"<>|",
          "depends_on": ""
        }
      ],
      "expected_response": {
        "success": "bool, 必填, 表示请求是否成功",
        "ret": {
          "type": "list[int]",
          "description": "返回加载的模型对象的唯一标识符",
          "structure": "ret[0] 为模型对象ID",
          "example": "[12345]"
        },
        "error": "str, 失败时的错误信息, 成功时通常为空",
        "abnormal_responses": [
          {
            "scenario": "文件路径不存在或非法",
            "success": false,
            "error": "模型路径无效或文件不存在"
          },
          {
            "scenario": "系统资源不足",
            "success": false,
            "error": "无法加载模型，系统资源不足"
          }
        ]
      },
      "upstream": {
        "must_call_before": [],
        "data_flow": [],
        "system_state": "系统处于空闲状态，且有足够资源加载模型"
      },
      "downstream": {
        "produces": [
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "sim.getObjectPosition, simArcs.webMoveObject, simArcs.webGetHandleType, simArcs.ahmCreateHierarchyElement",
            "as_param_index": 0,
            "desc": "模型对象ID用于后续操作"
          }
        ],
        "state_change": "成功调用后，系统中新增一个模型对象"
      },
      "business_rules": [
        "重复调用会加载多个模型对象",
        "幂等性：非幂等，重复调用会产生不同的对象ID"
      ]
    },
