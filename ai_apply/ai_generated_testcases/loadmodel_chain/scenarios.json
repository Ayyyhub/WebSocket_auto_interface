          "name": "test_webMoveObject_boundary_invalid_position",
          "description": "目标位置为极端空间坐标（边界值）",
          "category": "boundary",
          "priority": 2,
          "target_params": {
            "对象句柄": "handle_12345",
            "目标位置": [
              -1000000000.0,
              1000000000.0,
              0
            ],
            "操作类型": "2"
