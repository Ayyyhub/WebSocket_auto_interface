      "func": "sim.loadModel",
      "seq": 1,
      "business_meaning": "加载指定路径的模型文件，返回模型的唯一标识符，用于后续操作。",
      "interface_type": "command",
      "params": [
        {
          "index": 0,
          "params_name": "model_path",
          "type": "str",
          "required": 0,
          "valid_range": "文件路径字符串",
          "boundary_values": [],
          "enum_values": [],
          "special_char_limit": "路径中不能包含非法字符，如\\/:*?\"<>|",
          "depends_on": ""
        }
      ],
      "expected_response": {
        "success": "bool, 必填, 表示请求是否成功",
        "ret": {
          "type": "list[int]",
          "description": "返回加载模型的唯一标识符",
          "structure": "ret[0] 为模型的唯一标识符",
          "example": "[12345]"
        },
        "error": "str, 失败时的错误信息",
        "abnormal_responses": [
          {
            "scenario": "文件路径不存在或非法",
            "success": false,
            "error": "模型路径无效或文件不存在"
          },
          {
            "scenario": "系统资源不足",
            "success": false,
            "error": "加载模型失败，系统资源不足"
          }
        ]
      },
      "upstream": {
        "must_call_before": [],
        "data_flow": [],
        "system_state": "系统处于可加载模型的状态"
      },
      "downstream": {
        "produces": [
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "sim.getObjectPosition",
            "as_param_index": 0,
            "desc": "用于获取对象位置"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.webMoveObject",
            "as_param_index": 0,
            "desc": "用于移动对象"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.webGetHandleType",
            "as_param_index": 0,
            "desc": "用于获取对象的 handle 类型"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.ahmCreateHierarchyElement",
            "as_param_index": 0,
            "desc": "用于创建工作台节点"
          }
        ],
        "state_change": "系统新增一个模型对象"
      },
      "business_rules": [
        "重复调用会加载多个模型，需确保模型路径唯一性",
        "幂等性：路径相同的模型不会重复加载"
      ]
    },
