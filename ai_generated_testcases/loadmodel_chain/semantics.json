{
  "interfaces": [
    {
      "func": "sim.loadModel",
      "seq": 1,
      "business_meaning": "加载指定路径的模型文件到仿真环境中，返回模型的唯一标识符。此接口是整个工作流的起点，后续接口依赖其返回值。",
      "interface_type": "command",
      "params": [
        {
          "index": 0,
          "params_name": "model_path",
          "type": "str",
          "required": 0,
          "valid_range": "文件路径必须存在且可读",
          "boundary_values": [],
          "enum_values": [],
          "special_char_limit": "路径中不能包含非法字符，如 \\:*?\"<>|",
          "depends_on": ""
        }
      ],
      "expected_response": {
        "success": "bool, 必填, 表示请求是否成功",
        "ret": {
          "type": "list[int]",
          "description": "返回加载模型的唯一标识符",
          "structure": "ret[0] 为模型标识符",
          "example": "[12345]"
        },
        "error": "str, 失败时的错误信息, 成功时通常为空或不存在",
        "abnormal_responses": [
          {
            "scenario": "文件路径不存在或不可读",
            "success": false,
            "error": "模型文件路径无效"
          },
          {
            "scenario": "模型加载失败",
            "success": false,
            "error": "模型加载失败，请检查文件格式或路径"
          }
        ]
      },
      "upstream": {
        "must_call_before": [],
        "data_flow": [],
        "system_state": "系统处于初始状态"
      },
      "downstream": {
        "produces": [
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "sim.getObjectPosition",
            "as_param_index": 0,
            "desc": "模型标识符用于获取对象位置"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.webMoveObject",
            "as_param_index": 0,
            "desc": "模型标识符用于移动对象"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.webGetHandleType",
            "as_param_index": 0,
            "desc": "模型标识符用于获取handle类型"
          },
          {
            "field": "ret[0]",
            "type": "int",
            "consumed_by": "simArcs.ahmCreateHierarchyElement",
            "as_param_index": 0,
            "desc": "模型标识符用于创建工作台节点"
          }
        ],
        "state_change": "系统加载了一个新的模型"
      },
      "business_rules": [
        "重复调用会加载多个模型，返回多个标识符",
        "幂等性不适用，重复调用会产生不同的结果"
      ]
    },
